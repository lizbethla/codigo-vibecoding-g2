# Entorno (development | production)
DJANGO_ENV=development

# Django
SECRET_KEY=cambiar-por-una-clave-segura-generada-con-django-get-random-secret-key
DEBUG=True

# Base de datos (solo producción — Railway provee este valor automáticamente)
DATABASE_URL=postgresql://usuario:contrasena@host:5432/logistica_db

# Hosts permitidos en producción (separados por coma)
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS en producción (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Stripe (usar restricted key con prefijo rk_, nunca sk_)
STRIPE_SECRET_KEY=<tu-restricted-key-de-stripe>
STRIPE_PUBLISHABLE_KEY=<tu-publishable-key-de-stripe>
STRIPE_WEBHOOK_SECRET=<tu-webhook-secret-de-stripe>
STRIPE_SUCCESS_URL=http://localhost:3000/checkout/success
STRIPE_CANCEL_URL=http://localhost:3000/checkout/cancel
